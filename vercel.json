{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/auth.js", "use": "@vercel/node" },
    { "src": "api/check.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "api/auth.js" },
    { "src": "/api/check", "dest": "api/check.js" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
